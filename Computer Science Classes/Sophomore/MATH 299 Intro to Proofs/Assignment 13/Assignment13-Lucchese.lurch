            <OMSTR>weight{75}</OMSTR>
          </OMATP>
          <OMSTR>Theorem:</OMSTR>
        </OMATTR>
        <OMSTR> if z is a natural number, then z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>1</OMSTR>
        </OMATTR>
        <OMSTR>=z</OMSTR>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
        <OMS cd="LurchUI" name="blockFormat"/>
        <OMSTR>linespace{100}</OMSTR>
      </OMATP>
      <OMA>
        <OMS cd="LurchUI" name="Block"/>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
        <OMS cd="LurchUI" name="blockFormat"/>
        <OMSTR>linespace{100}</OMSTR>
      </OMATP>
      <OMA>
        <OMS cd="LurchUI" name="Block"/>
        <OMSTR>	Assume z is a natural number</OMSTR>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
        <OMS cd="LurchUI" name="blockFormat"/>
        <OMSTR>linespace{100}</OMSTR>
      </OMATP>
      <OMA>
        <OMS cd="LurchUI" name="Block"/>
        <OMSTR>	z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>n +1 </OMSTR>
        </OMATTR>
        <OMSTR> = z &#x22c5; z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>n</OMSTR>
        </OMATTR>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
        <OMS cd="LurchUI" name="blockFormat"/>
        <OMSTR>linespace{100}</OMSTR>
      </OMATP>
      <OMA>
        <OMS cd="LurchUI" name="Block"/>
        <OMSTR>	z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>0 + 1</OMSTR>
        </OMATTR>
        <OMSTR> = z &#x22c5; z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>0			</OMSTR>
        </OMATTR>
        <OMSTR>by substitution</OMSTR>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
        <OMS cd="LurchUI" name="blockFormat"/>
        <OMSTR>linespace{100}</OMSTR>
      </OMATP>
      <OMA>
        <OMS cd="LurchUI" name="Block"/>
        <OMSTR>	z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>1</OMSTR>
        </OMATTR>
        <OMSTR>     = z &#x22c5; z</OMSTR>
        <OMATTR>
          <OMATP>
            <OMS cd="LurchUI" name="charFormat"/>
            <OMSTR>vertical{1}</OMSTR>
          </OMATP>
          <OMSTR>0</OMSTR>
        </OMATTR>
        <OMSTR>			by additive identity</OMSTR>
      </OMA>
    </OMATTR>
    <OMATTR>
      <OMATP>
