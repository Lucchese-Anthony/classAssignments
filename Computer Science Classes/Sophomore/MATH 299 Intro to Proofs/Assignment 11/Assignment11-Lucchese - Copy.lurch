        </OMATP>
        <OMSTR>Theorem: </OMSTR>
      </OMATTR>
      <OMSTR>&#x2200;n, 1 &#x2022; n= n and n &#x2022; 1 = n</OMSTR>
    </OMA>
    <OMA>
